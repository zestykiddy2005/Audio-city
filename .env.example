# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SPOTIFY_CLIENT_ID: Required for Spotify Web API features. Configure in AI Studio Secrets panel.
SPOTIFY_CLIENT_ID=SPOTIFY_CLIENT_ID_DEFAULT_VALUE

# SPOTIFY_CLIENT_SECRET: Required for Spotify Web API features. Configure in AI Studio Secrets panel.
SPOTIFY_CLIENT_SECRET=SPOTIFY_CLIENT_SECRET_DEFAULT_VALUE

# YOUTUBE_API_KEY: Optional/Required for YouTube API features. Configure in AI Studio Secrets panel.
YOUTUBE_API_KEY=YOUTUBE_API_KEY_DEFAULT_VALUE

